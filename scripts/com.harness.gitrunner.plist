<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.harness.gitrunner</string>

    <!-- Every 30 seconds, check the .git-sync-queue/ directory for commit
         markers written by the harness (which lives in a sandbox that
         cannot run git directly). Each marker describes a commit the
         harness wants made; this runner adds, commits, and pushes for
         it, then removes the marker. -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/rfoxes/Stock-Trading-Agent/scripts/process_git_sync_queue.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>30</integer>

    <key>RunAtLoad</key>
    <true/>

    <!-- Run with the user's PATH so /usr/bin/git is found. -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/harness-gitrunner.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/harness-gitrunner.err</string>
</dict>
</plist>
