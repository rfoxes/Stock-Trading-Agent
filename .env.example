# =============================================================================
# Quant Trading System Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- LLM Provider ---
# "anthropic" for Claude (paid, requires ANTHROPIC_API_KEY)
# "ollama" for local models (free, requires Ollama running at http://localhost:11434)
LLM_PROVIDER=anthropic

# --- Anthropic (only needed when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Ollama (only needed when LLM_PROVIDER=ollama) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# --- Alpaca (Paper Trading) ---
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
# IMPORTANT: Keep this as true. Only set to false when explicitly ready for live trading.
ALPACA_PAPER=true

# --- Safety Gate ---
# CRITICAL: Both must be true AND ALPACA_PAPER must be false for live trading.
# DO NOT change these until you are explicitly ready for real money.
REAL_MONEY_ENABLED=false
REAL_MONEY_CONFIRMATION=false

# --- Database (PostgreSQL for LangGraph checkpointing) ---
DATABASE_URL=postgresql://trading:trading@localhost:5432/trading_system
# Set to "memory" to skip PostgreSQL dependency during development
LANGGRAPH_CHECKPOINTER=memory

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data

# --- Portfolio Settings (Paper) ---
PAPER_PORTFOLIO_SIZE=100000

# --- Risk Limits ---
MAX_POSITION_SIZE_PCT=0.10
MAX_SECTOR_CONCENTRATION_PCT=0.25
MAX_DRAWDOWN_PAUSE_PCT=0.15
MAX_DAILY_LOSS_PCT=0.02
MAX_CONCURRENT_POSITIONS=20

# --- Agent Model Allocation ---
SUPERVISOR_MODEL=claude-sonnet-4-5-20250514
ANALYSIS_MODEL=claude-sonnet-4-5-20250514
ROUTING_MODEL=claude-haiku-4-5-20251001
EXECUTION_MODEL=claude-haiku-4-5-20251001

# --- Watchlist (comma-separated) ---
DEFAULT_WATCHLIST=SPY,QQQ,AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM

# --- Scheduling ---
INTRADAY_INTERVAL_MINUTES=5
SWING_REBALANCE_TIME=15:50
POSITION_REBALANCE_DAY=friday
STRATEGY_RESEARCH_INTERVAL_DAYS=7

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Dry Run ---
# Set to true to run full pipeline without submitting any orders
DRY_RUN=false
