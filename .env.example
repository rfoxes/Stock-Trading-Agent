# =============================================================================
# Trading Harness Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Anthropic (required) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Default model for the orchestrator. Override if you want a different one.
SUPERVISOR_MODEL=claude-sonnet-4-6

# --- Alpaca (required for paper trading) ---
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
# Keep this true. Live trading requires both safety flags below.
ALPACA_PAPER=true

# --- Safety Gate ---
# Both must be true AND ALPACA_PAPER must be false for live trading.
# Don't change these until you're explicitly ready for real money.
REAL_MONEY_ENABLED=false
REAL_MONEY_CONFIRMATION=false

# --- Portfolio Settings (Paper) ---
PAPER_PORTFOLIO_SIZE=100000

# --- Risk Limits ---
MAX_POSITION_SIZE_PCT=0.10
MAX_SECTOR_CONCENTRATION_PCT=0.25
MAX_DRAWDOWN_PAUSE_PCT=0.15
MAX_DAILY_LOSS_PCT=0.02
MAX_CONCURRENT_POSITIONS=20
RESTRICTED_SYMBOLS=

# --- Watchlist (comma-separated) ---
DEFAULT_WATCHLIST=SPY,QQQ,AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Dry Run ---
# Set true to run the agent without ever submitting orders to the broker.
DRY_RUN=false
